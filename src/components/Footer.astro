---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__top">
      <div class="footer__brand">
        <div class="footer__logo">
          <span class="footer__mark">GV</span>
          <span class="footer__wordmark">Global Village</span>
        </div>
        <p class="footer__tagline">Where culture earns.</p>
      </div>

      <div class="footer__links">
        <div class="footer__col">
          <h4>Product</h4>
          <a href="#features">Features</a>
          <a href="#earnings">Earnings</a>
          <a href="#manifesto">Manifesto</a>
        </div>
        <div class="footer__col">
          <h4>Community</h4>
          <a href="#">Discord</a>
          <a href="#">Twitter / X</a>
          <a href="#">Instagram</a>
        </div>
        <div class="footer__col">
          <h4>Legal</h4>
          <a href="#">Privacy Policy</a>
          <a href="#">Terms of Service</a>
          <a href="#">Cookie Policy</a>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {year} Global Village Platforms, Inc. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--charcoal);
    color: #fff;
    padding-block: 4rem 2rem;
  }

  .footer__top {
    display: flex;
    justify-content: space-between;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.75rem;
  }

  .footer__mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--olive);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 800;
    border-radius: 0.375rem;
  }

  .footer__wordmark {
    font-size: 1.125rem;
    font-weight: 700;
  }

  .footer__tagline {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9375rem;
  }

  .footer__links {
    display: flex;
    gap: 4rem;
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer__col h4 {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 0.375rem;
  }

  .footer__col a {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.15s;
  }

  .footer__col a:hover {
    color: #fff;
  }

  .footer__bottom {
    padding-top: 2rem;
  }

  .footer__bottom p {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.35);
  }

  @media (max-width: 768px) {
    .footer__top {
      flex-direction: column;
    }

    .footer__links {
      gap: 2.5rem;
      flex-wrap: wrap;
    }
  }
</style>
